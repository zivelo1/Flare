    <string name="onboarding_get_started">Get Started</string>
    <string name="onboarding_title_1">No Internet Needed</string>
    <string name="onboarding_desc_1">Flare sends messages phone to phone using Bluetooth. No servers, no Wi-Fi, no cell service. Your messages hop through other Flare users until they reach your contact.</string>
    <string name="onboarding_title_2">End-to-End Encrypted</string>
    <string name="onboarding_desc_2">Every message is encrypted on your phone before it leaves. Nobody in between can read your messages — not even the people whose phones relay them.</string>
    <string name="onboarding_title_3">Find Your Friends</string>
    <string name="onboarding_desc_3">Enter a shared phrase that you and your friend both know — a memory, a place, an inside joke. Flare searches the mesh and connects you securely.</string>
    <string name="onboarding_title_4">Designed for Safety</string>
    <string name="onboarding_desc_4">Destruction code permanently erases all data if you are forced to unlock. No accounts, no phone number required, no tracking. Your privacy is protected by design.</string>

