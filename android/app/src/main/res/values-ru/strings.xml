    <!-- Duress Settings -->
    <string name="duress_title">PIN под принуждением</string>
    <string name="duress_plausible_deniability">Правдоподобное отрицание</string>
    <string name="duress_explanation">Если вас принуждают разблокировать Flare, ввод PIN под принуждением открывает обманную базу данных с безобидными сообщениями. Ваши настоящие разговоры остаются скрытыми и зашифрованными.</string>
    <string name="duress_active_title">PIN под принуждением активен</string>
    <string name="duress_active_description">При вводе PIN под принуждением будет показана обманная база данных.</string>
    <string name="duress_remove_button">Удалить PIN под принуждением</string>
    <string name="duress_passphrase_label">Пароль под принуждением</string>
    <string name="duress_confirm_label">Подтвердите пароль</string>
    <string name="duress_mismatch">Пароли не совпадают</string>
    <string name="duress_warning">Выберите пароль, который вы сможете вспомнить в стрессовой ситуации. Он должен отличаться от вашего основного пароля. Если вы его забудете, восстановить его будет невозможно.</string>
    <string name="duress_set_button">Установить PIN под принуждением</string>
