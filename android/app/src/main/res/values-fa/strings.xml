    <!-- رمز اضطراری -->
    <string name="duress_title">رمز اضطراری</string>
    <string name="duress_plausible_deniability">انکارپذیری قابل قبول</string>
    <string name="duress_explanation">اگر مجبور به باز کردن Flare شدید، وارد کردن رمز اضطراری یک پایگاه داده پوششی با پیام‌های بی‌ضرر باز می‌کند. گفتگوهای واقعی شما مخفی و رمزنگاری‌شده باقی می‌مانند.</string>
    <string name="duress_active_title">رمز اضطراری فعال</string>
    <string name="duress_active_description">هنگام وارد کردن رمز اضطراری، پایگاه داده پوششی نمایش داده می‌شود.</string>
    <string name="duress_remove_button">حذف رمز اضطراری</string>
    <string name="duress_passphrase_label">عبارت عبور اضطراری</string>
    <string name="duress_confirm_label">تأیید عبارت عبور</string>
    <string name="duress_mismatch">عبارات عبور مطابقت ندارند</string>
    <string name="duress_warning">عبارت عبوری انتخاب کنید که بتوانید در شرایط فشار به خاطر بیاورید. باید با عبارت عبور اصلی شما متفاوت باشد. اگر آن را فراموش کنید، راهی برای بازیابی وجود ندارد.</string>
    <string name="duress_set_button">تنظیم رمز اضطراری</string>
    <string name="duress_set_success">رمز اضطراری با موفقیت تنظیم شد</string>
    <string name="duress_set_error">تنظیم رمز اضطراری ناموفق بود. لطفاً دوباره تلاش کنید.</string>
    <string name="duress_remove_dialog_title">حذف رمز اضطراری؟</string>
    <string name="duress_remove_dialog_message">این کار انکارپذیری را غیرفعال می‌کند. هر کسی که شما را مجبور به باز کردن Flare کند، گفتگوهای واقعی شما را خواهد دید.</string>
    <string name="duress_remove_confirm">حذف</string>

