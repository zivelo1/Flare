    <string name="find_shared_phrase_title">عبارت مشترک</string>
    <string name="find_shared_phrase_desc">عبارتی وارد کنید که فقط شما و دوستتان می‌دانید. یک خاطره مشترک، یک مکان، یک شوخی بین خودتان. امن‌ترین روش.</string>
    <string name="find_recommended">پیشنهادی</string>
    <string name="find_share_link_title">اشتراک‌گذاری لینک هویت</string>
    <string name="find_share_link_desc">هویت Flare خود را از طریق پیامک، واتساپ یا هر برنامه‌ای ارسال کنید. در هر فاصله‌ای کار می‌کند — نیازی به مش نیست.</string>
    <string name="find_qr_title">اسکن کد QR</string>
    <string name="find_qr_desc">کد QR مخاطبتان را هنگام ملاقات حضوری اسکن کنید. حداکثر امنیت — بدون نوردهی شبکه.</string>
    <string name="find_phone_title">شماره تلفن</string>
    <string name="find_phone_desc">جستجو با شماره تلفن. هر دو طرف باید شماره یکدیگر را وارد کنند. امنیت کمتر در برابر دشمنان قدرتمند.</string>
    <string name="find_import_title">وارد کردن مخاطبین</string>
    <string name="find_import_desc">مخاطبین تلفن خود را وارد کنید تا به طور خودکار دوستانی را پیدا کنید که از Flare استفاده می‌کنند. نیاز به مجوز خواندن مخاطبین.</string>

    <!-- جستجوی عبارت مشترک -->
    <string name="phrase_search_title">عبارت مشترک</string>
    <string name="phrase_search_instructions">عبارتی وارد کنید که فقط شما و دوستتان می‌دانید. می‌تواند یک خاطره مشترک، مکانی که هر دو رفته‌اید، یا هر چیز منحصربه‌فرد بین شما باشد.</string>
    <string name="phrase_search_label">عبارت مشترک</string>
    <string name="phrase_search_placeholder">مثلاً خانه مادربزرگ در خیابان حافظ</string>
    <string name="phrase_search_hint">دوستتان باید دقیقاً همان عبارت را در برنامه Flare خود وارد کند. بزرگ و کوچک بودن حروف و فاصله‌های اضافی مهم نیست.</string>
    <string name="phrase_search_button">جستجوی مش</string>
