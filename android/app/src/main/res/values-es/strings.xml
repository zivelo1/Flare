    <string name="power_how_tiers_work">Cómo funcionan los niveles de energía</string>
    <string name="power_tier_active">ACTIVO</string>
    <string name="power_high_description">Escaneo casi continuo. Máxima velocidad de descubrimiento. Se usa durante el intercambio activo de datos (máx. %ds).</string>
    <string name="power_balanced_description">Escaneo con ciclo de trabajo del 25%%. Buen equilibrio entre descubrimiento y batería. Baja a bajo consumo después de %ds sin pares.</string>
    <string name="power_low_description">Modo ráfaga — escanea %1$ds cada %2$ds (~17%% activo).</string>
    <string name="power_ultralow_description">Escaneo mínimo — %1$ds cada %2$ds (~5%% activo). Se activa por debajo del %3$d%% de batería.</string>
    <string name="power_auto_adjust">Flare ajusta automáticamente el nivel de energía según la actividad de la red, la presencia de pares y el nivel de batería. El nivel alto se desactiva por debajo del %d%% de batería.</string>

