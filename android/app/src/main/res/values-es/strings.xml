    <!-- Destruction Settings -->
    <string name="destruction_title">Código de destrucción</string>
    <string name="destruction_plausible_deniability">Borrado de datos de emergencia</string>
    <string name="destruction_explanation">Si te obligan a desbloquear Flare, al ingresar el código de destrucción se borran permanentemente todos los mensajes, contactos y tu identidad. La app aparecerá como recién instalada. Esto no se puede deshacer.</string>
    <string name="destruction_active_title">Código de destrucción activo</string>
    <string name="destruction_active_description">Una pantalla de bloqueo aparece en cada inicio. Al ingresar el código de destrucción se borran permanentemente todos los datos.</string>
    <string name="destruction_remove_button">Eliminar código de destrucción</string>
    <string name="destruction_unlock_code_label">Código de desbloqueo</string>
    <string name="destruction_unlock_code_hint">Código para abrir la app normalmente</string>
    <string name="destruction_code_label">Código de destrucción</string>
    <string name="destruction_code_hint">Código que borra todo</string>
    <string name="destruction_confirm_label">Confirmar código de destrucción</string>
    <string name="destruction_mismatch">Los códigos de destrucción no coinciden</string>
    <string name="destruction_codes_same">El código de desbloqueo y el código de destrucción deben ser diferentes</string>
    <string name="destruction_warning">ADVERTENCIA: El código de destrucción borra permanente e irreversiblemente TODOS los datos — mensajes, contactos y tu identidad. No hay recuperación. Elige códigos que puedas recordar bajo estrés extremo.</string>
    <string name="destruction_set_button">Activar código de destrucción</string>
    <string name="destruction_set_success">Código de destrucción activado</string>
    <string name="destruction_set_error">No se pudo establecer el código de destrucción. Inténtalo de nuevo.</string>
    <string name="destruction_remove_dialog_title">¿Eliminar código de destrucción?</string>
    <string name="destruction_remove_dialog_message">Esto elimina la pantalla de bloqueo y el código de destrucción. Cualquier persona con acceso a tu teléfono puede abrir Flare y ver tus conversaciones.</string>
    <string name="destruction_remove_confirm">Eliminar</string>
