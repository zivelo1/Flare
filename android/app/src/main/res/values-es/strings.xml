    <!-- Find Contact -->
    <string name="find_contact_title">Buscar un contacto</string>
    <string name="find_contact_subtitle">Elige cómo encontrar a tu contacto</string>
    <string name="find_shared_phrase_title">Frase compartida</string>
    <string name="find_shared_phrase_desc">Ingresa una frase que solo tú y tu amigo conozcan. Un recuerdo compartido, un lugar, un chiste interno. La opción más segura.</string>
    <string name="find_recommended">Recomendado</string>
    <string name="find_share_link_title">Compartir enlace de identidad</string>
    <string name="find_share_link_desc">Envía tu identidad de Flare por SMS, WhatsApp o cualquier app. Funciona a cualquier distancia — no se necesita la red mesh.</string>
    <string name="find_qr_title">Escanear código QR</string>
    <string name="find_qr_desc">Escanea el código QR de tu contacto cuando se encuentren en persona. Máxima seguridad — cero exposición en la red.</string>
    <string name="find_phone_title">Número de teléfono</string>
    <string name="find_phone_desc">Buscar por número de teléfono. Ambas partes deben ingresar el número del otro. Menos seguro contra adversarios con muchos recursos.</string>
    <string name="find_import_title">Importar contactos</string>
    <string name="find_import_desc">Importa los contactos de tu teléfono para encontrar automáticamente amigos que también usan Flare. Requiere permiso READ_CONTACTS.</string>

    <!-- Shared Phrase Search -->
    <string name="phrase_search_title">Frase compartida</string>
    <string name="phrase_search_instructions">Ingresa una frase que solo tú y tu amigo conozcan. Puede ser un recuerdo compartido, un lugar que ambos visitaron o algo único entre ustedes.</string>
    <string name="phrase_search_label">Frase compartida</string>
    <string name="phrase_search_placeholder">ej., la casa de la abuela en la calle bolívar</string>
    <string name="phrase_search_hint">Tu amigo debe ingresar la MISMA frase exacta en su app de Flare. Las mayúsculas y los espacios extra no importan.</string>
    <string name="phrase_search_button">Buscar en la red mesh</string>
    <string name="phrase_searching">Buscando en la red mesh…</string>
    <string name="phrase_searching_desc">Transmitiendo tu token de encuentro a dispositivos cercanos. Esto puede tomar minutos, horas o días dependiendo de la conectividad mesh con tu amigo.</string>
    <string name="phrase_searching_privacy">Tu frase nunca sale de este dispositivo. Solo se transmite una huella matemática — no se puede revertir.</string>
    <string name="phrase_cancel">Cancelar búsqueda</string>
    <string name="phrase_found">¡Contacto encontrado!</string>
    <string name="phrase_found_via">Encontrado vía %s</string>
    <string name="phrase_add_contact">Agregar contacto</string>

    <!-- Phone Search -->
    <string name="phone_search_title">Búsqueda por número de teléfono</string>
    <string name="phone_security_notice">Aviso de seguridad</string>
    <string name="phone_security_warning">Un adversario con muchos recursos que conozca TU número de teléfono podría determinar a quién intentas contactar. Usa \"Frase compartida\" si te preocupa la vigilancia gubernamental.</string>
    <string name="phone_your_number">Tu número de teléfono</string>
    <string name="phone_your_placeholder">+58 412 123 4567</string>
    <string name="phone_their_number">Su número de teléfono</string>
    <string name="phone_their_placeholder">+58 414 987 6543</string>
    <string name="phone_accept_risk">Entiendo las limitaciones de seguridad</string>
    <string name="phone_searching_desc">Ambos números de teléfono se combinan en un solo token. Solo alguien que conozca ambos números puede hacer la coincidencia.</string>
    <string name="phone_instructions">Tu amigo también debe ingresar TU número de teléfono en su app. Ningún número de teléfono se envía por la red.</string>

    <!-- Onboarding -->
    <string name="onboarding_title_1">No se necesita internet</string>
    <string name="onboarding_desc_1">Flare envía mensajes de teléfono a teléfono usando Bluetooth. Sin servidores, sin Wi-Fi, sin servicio celular. Tus mensajes saltan a través de otros usuarios de Flare hasta llegar a tu contacto.</string>
    <string name="onboarding_title_2">Cifrado de extremo a extremo</string>
    <string name="onboarding_desc_2">Cada mensaje se cifra en tu teléfono antes de salir. Nadie en el medio puede leer tus mensajes — ni siquiera las personas cuyos teléfonos los retransmiten.</string>
    <string name="onboarding_title_3">Encuentra a tus amigos</string>
    <string name="onboarding_desc_3">Ingresa una frase compartida que tú y tu amigo conozcan — un recuerdo, un lugar, un chiste interno. Flare busca en la red mesh y los conecta de forma segura.</string>
    <string name="onboarding_title_4">Diseñado para la seguridad</string>
    <string name="onboarding_desc_4">El PIN de emergencia abre una base de datos falsa si te obligan a desbloquear. Sin cuentas, sin número de teléfono requerido, sin rastreo. Tu privacidad está protegida por diseño.</string>

