    <!-- Phone Search -->
    <string name="phone_search_title">전화번호 검색</string>
    <string name="phone_security_notice">보안 공지</string>
    <string name="phone_security_warning">당신의 전화번호를 아는 자금력이 풍부한 적대자가 당신이 연락하려는 사람을 파악할 수 있습니다. 정부 감시가 우려되면 \"공유 문구\"를 사용하세요.</string>
    <string name="phone_your_number">내 전화번호</string>
