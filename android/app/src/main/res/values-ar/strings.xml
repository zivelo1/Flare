    <!-- Shared Phrase Search -->
    <string name="phrase_search_title">عبارة مشتركة</string>
    <string name="phrase_search_instructions">أدخل عبارة لا يعرفها سواك أنت وصديقك. يمكن أن تكون ذكرى مشتركة، مكان زرتماه معًا، أو أي شيء فريد بينكما.</string>
    <string name="phrase_search_label">العبارة المشتركة</string>
    <string name="phrase_search_placeholder">مثال: بيت جدتي في شارع الحمراء</string>
    <string name="phrase_search_hint">يجب على صديقك إدخال نفس العبارة بالضبط في تطبيق Flare الخاص به. لا تؤثر حالة الأحرف والمسافات الزائدة.</string>
