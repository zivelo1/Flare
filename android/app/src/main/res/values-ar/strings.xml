    <!-- Onboarding -->
    <string name="onboarding_skip">تخطي</string>
    <string name="onboarding_next">التالي</string>
    <string name="onboarding_back">رجوع</string>
    <string name="onboarding_get_started">ابدأ الآن</string>
    <string name="onboarding_title_1">لا حاجة للإنترنت</string>
    <string name="onboarding_desc_1">يرسل Flare الرسائل من هاتف إلى هاتف عبر البلوتوث. لا خوادم، لا واي فاي، لا خدمة اتصالات. تنتقل رسائلك عبر مستخدمي Flare الآخرين حتى تصل إلى جهة اتصالك.</string>
    <string name="onboarding_title_2">تشفير من طرف إلى طرف</string>
    <string name="onboarding_desc_2">يتم تشفير كل رسالة على هاتفك قبل إرسالها. لا أحد في الوسط يمكنه قراءة رسائلك — ولا حتى الأشخاص الذين تمر رسائلك عبر هواتفهم.</string>
    <string name="onboarding_title_3">ابحث عن أصدقائك</string>
    <string name="onboarding_desc_3">أدخل عبارة مشتركة تعرفها أنت وصديقك — ذكرى، مكان، أو نكتة بينكما. يبحث Flare في الشبكة المتداخلة ويربطكما بأمان.</string>
    <string name="onboarding_title_4">مصمّم من أجل سلامتك</string>
    <string name="onboarding_desc_4">رمز الإكراه يفتح قاعدة بيانات وهمية إذا أُجبرت على فتح التطبيق. لا حسابات، لا رقم هاتف مطلوب، لا تتبع. خصوصيتك محمية بالتصميم.</string>

