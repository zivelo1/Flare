    <!-- Duress Settings -->
    <string name="duress_title">رمز الإكراه</string>
    <string name="duress_plausible_deniability">الإنكار المعقول</string>
    <string name="duress_explanation">إذا أُجبرت على فتح Flare، فإن إدخال رمز الإكراه يفتح قاعدة بيانات وهمية تحتوي على رسائل عادية. تبقى محادثاتك الحقيقية مخفية ومشفرة.</string>
    <string name="duress_active_title">رمز الإكراه مفعّل</string>
    <string name="duress_active_description">ستُعرض قاعدة بيانات وهمية عند إدخال رمز الإكراه.</string>
    <string name="duress_remove_button">إزالة رمز الإكراه</string>
    <string name="duress_passphrase_label">عبارة مرور الإكراه</string>
    <string name="duress_confirm_label">تأكيد عبارة المرور</string>
    <string name="duress_mismatch">عبارتا المرور غير متطابقتين</string>
    <string name="duress_warning">اختر عبارة مرور يمكنك تذكرها تحت الضغط. يجب أن تكون مختلفة عن عبارة المرور الرئيسية. إذا نسيتها، لا توجد طريقة لاستعادتها.</string>
    <string name="duress_set_button">تعيين رمز الإكراه</string>
    <string name="duress_set_success">تم تعيين رمز الإكراه بنجاح</string>
    <string name="duress_set_error">فشل تعيين رمز الإكراه. يرجى المحاولة مرة أخرى.</string>
